# Render assets/attention.gif — run from the repo root:  vhs assets/attention.tape
Output assets/attention.gif

Set FontSize 16
Set Width 1000
Set Height 600
Set Padding 20
Set WaitTimeout 120s

Type ".venv/bin/python attention.py --generate checkpoints/attention_CS32_NE64_NH4.pt --num_tokens 5000"
Enter
Wait
