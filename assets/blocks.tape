# Render assets/blocks.gif — run from the repo root:  vhs assets/blocks.tape
Output assets/blocks.gif

Set FontSize 16
Set Width 1000
Set Height 600
Set Padding 20
Set WaitTimeout 120s

Type ".venv/bin/python blocks.py --generate checkpoints/blocks_CS32_NE64_NH4_NL4_D0.1.pt --num_tokens 1000"
Enter
Wait
